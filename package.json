{
  "name": "daily-visual-planner",
  "private": true,
  "version": "1.0.0",
  "description": "Desktop day planner: timeline blocks, Google Calendar/Tasks & Slack integration (Electron + React + TypeScript)",
  "license": "MIT",
  "author": "chamakkon",
  "repository": {
    "type": "git",
    "url": "https://github.com/chamakkon/ScheduleBlocker.git"
  },
  "keywords": [
    "electron",
    "react",
    "typescript",
    "planner",
    "calendar",
    "slack",
    "productivity"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "ELECTRON_RUN_AS_NODE= vite",
    "build": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.dailyvisualplanner.app",
    "productName": "Daily Visual Planner",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "target": "dir"
    },
    "extraResources": []
  },
  "dependencies": {
    "googleapis": "^171.4.0",
    "html-to-image": "^1.11.13",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
